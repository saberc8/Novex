# Root POC aggregate env. Use project-local .env.example files for standalone
# backend, parser-worker, or frontend app development.

AUTH_JWT_SECRET=local-compose-change-this-secret-32chars-min
AUTH_JWT_TTL_HOURS=24
HTTP_PORT=62601
DATABASE_MAX_CONNECTIONS=5
DB_AUTO_MIGRATE=true
LOGIN_CAPTCHA_ENABLED=false
RUST_LOG=backend=debug,tower_http=info

# Shared docker-common infrastructure. Start it from:
# /path/to/docker-common/docker-compose.yml
COMMON_DOCKER_NETWORK=docker-common_default
COMMON_POSTGRES_USER=postgres
COMMON_POSTGRES_PASSWORD=postgres
COMMON_POSTGRES_DATABASE=novex
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:15432/novex
REDIS_URL=redis://127.0.0.1:16379/0
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5673/%2f
MILVUS_ENDPOINT=http://127.0.0.1:19540
MINIO_ENDPOINT=http://127.0.0.1:19010
MINIO_CONSOLE_URL=http://127.0.0.1:19011
NEO4J_URI=bolt://127.0.0.1:17687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j-password
ATTU_URL=http://127.0.0.1:18000
RABBITMQ_MANAGEMENT_URL=http://127.0.0.1:15673
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Optional Novex frontend dev port references.
ADMIN_PORT=62602
TRAINING_WEB_PORT=62603
NOTEBOOKLM_PORT=62604
AGENT_WORKSPACE_PORT=62605
CODEX_APP_POC_PORT=62606
CORS_ALLOWED_ORIGINS=http://localhost:62602,http://127.0.0.1:62602,http://localhost:62603,http://127.0.0.1:62603,http://localhost:62604,http://127.0.0.1:62604,http://localhost:62605,http://127.0.0.1:62605,http://localhost:62606,http://127.0.0.1:62606
NEXT_PUBLIC_API_BASE_URL=http://localhost:62601

# Parser queue and callback settings.
PARSER_CALLBACK_TOKEN=local-parser-callback-token-change-me
PARSER_CALLBACK_USER_ID=1
PARSER_BACKEND_BASE_URL=http://127.0.0.1:62601
PARSER_BACKEND_TOKEN=local-parser-callback-token-change-me
PARSER_QUEUE_ENABLED=true
PARSER_QUEUE_PUBLISHER_ENABLED=true
PARSER_QUEUE_TICK_SECONDS=5
PARSER_QUEUE_BATCH_SIZE=50
RABBITMQ_PARSER_EXCHANGE=novex.parser
RABBITMQ_PARSER_EXECUTE_QUEUE=novex.parser.execute
RABBITMQ_PARSER_RETRY_QUEUE=novex.parser.retry
RABBITMQ_PARSER_DEAD_QUEUE=novex.parser.dead
RABBITMQ_PARSER_EXECUTE_ROUTING_KEY=parser.execute
RABBITMQ_PARSER_RETRY_ROUTING_KEY=parser.retry
RABBITMQ_PARSER_DEAD_ROUTING_KEY=parser.dead
RABBITMQ_PARSER_RETRY_TTL_MS=30000
PARSER_WORKER_ID=parser-worker-1
PARSER_WORKER_MODE=type-routed

AGENT_QUEUE_ENABLED=false
AGENT_QUEUE_PUBLISHER_ENABLED=false
AGENT_QUEUE_TICK_SECONDS=2
AGENT_QUEUE_BATCH_SIZE=10
AGENT_QUEUE_LEASE_SECONDS=120
AGENT_QUEUE_MAX_ATTEMPTS=3
RABBITMQ_AGENT_EXCHANGE=novex.agent
RABBITMQ_AGENT_EXECUTE_QUEUE=novex.agent.execute
RABBITMQ_AGENT_RETRY_QUEUE=novex.agent.retry
RABBITMQ_AGENT_DEAD_QUEUE=novex.agent.dead
RABBITMQ_AGENT_EXECUTE_ROUTING_KEY=agent.execute
RABBITMQ_AGENT_RETRY_ROUTING_KEY=agent.retry
RABBITMQ_AGENT_DEAD_ROUTING_KEY=agent.dead
RABBITMQ_AGENT_RETRY_TTL_MS=30000

EVAL_QUEUE_ENABLED=true
EVAL_QUEUE_PUBLISHER_ENABLED=true
EVAL_QUEUE_TICK_SECONDS=5
EVAL_QUEUE_BATCH_SIZE=50
EVAL_WORKER_ID=eval-worker-1
EVAL_TASK_TIMEOUT_SECONDS=180
RABBITMQ_EVAL_EXCHANGE=novex.eval
RABBITMQ_EVAL_EXECUTE_QUEUE=novex.eval.execute
RABBITMQ_EVAL_RETRY_QUEUE=novex.eval.retry
RABBITMQ_EVAL_DEAD_QUEUE=novex.eval.dead
RABBITMQ_EVAL_EXECUTE_ROUTING_KEY=eval.execute
RABBITMQ_EVAL_RETRY_ROUTING_KEY=eval.retry
RABBITMQ_EVAL_DEAD_ROUTING_KEY=eval.dead
RABBITMQ_EVAL_RETRY_TTL_MS=30000

# Agent web.search provider chain.
# Default when unset: google_news_rss. Chain order is left-to-right fallback.
# Free RSS providers need no key; Tavily/Brave need keys; SearXNG points to a self-hosted instance.
NOVEX_WEB_SEARCH_PROVIDERS=google_news_rss
# NOVEX_WEB_SEARCH_PROVIDERS=tavily,brave,searxng,bing_news_rss,google_news_rss
# NOVEX_TAVILY_API_KEY=
# NOVEX_BRAVE_SEARCH_API_KEY=
# NOVEX_SEARXNG_ENDPOINT=http://localhost:8080/search

# Optional external integration credentials for live POC smoke runs.
# Codex-style Agent POC uses runtime.llm.code_agent through the existing LLM route.
AGENT_RUNTIME_MODE=model_loop
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
RERANKER_API_KEY=
RERANKER_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
RERANKER_MODEL=qwen3-rerank
MINERU_TOKEN=
MINERU_TIMEOUT_SECONDS=120
GITHUB_CONNECTOR_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
FEISHU_WEBHOOK_URL=
RIGHT_CODE_DRAW_BASE_URL=
RIGHT_CODE_DRAW_API_KEY=

# Milvus standalone default from the shared docker-common stack.
MILVUS_TOKEN=root:Milvus
