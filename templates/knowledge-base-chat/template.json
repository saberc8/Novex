{
  "code": "knowledge_base_chat",
  "name": "Knowledge Base Chat",
  "category": "knowledge",
  "description": "RAG chat template for policies, product documentation, FAQ, and enterprise knowledge with citations.",
  "frontendEntry": "apps/chat-web",
  "frontendApp": "chat-web",
  "frontendPages": [
    {
      "code": "ask",
      "title": "Knowledge Q&A",
      "path": "/knowledge",
      "navLabel": "Ask",
      "permission": "app:knowledge:ask"
    },
    {
      "code": "sources",
      "title": "Sources",
      "path": "/knowledge/sources",
      "navLabel": "Sources",
      "permission": "ai:knowledge:list"
    },
    {
      "code": "share",
      "title": "Public Share",
      "path": "/share/[token]",
      "navLabel": "Share",
      "permission": "app:knowledge:ask"
    }
  ],
  "smokeScript": "templates/knowledge-base-chat/smoke.sh",
  "smokeChecks": [
    {
      "code": "chat_web_frontend",
      "name": "Chat Web Frontend Smoke",
      "workdir": "apps/chat-web",
      "command": "pnpm test"
    },
    {
      "code": "knowledge_base_api",
      "name": "Knowledge Base API Smoke",
      "workdir": "backend",
      "command": "cargo test -p backend-rust knowledge --offline"
    }
  ],
  "sort": 2,
  "status": 1,
  "branding": {
    "brandName": "Novex Knowledge",
    "logoText": "KB",
    "primaryColor": "#0f766e",
    "publicUrl": "https://kb.example.com"
  },
  "roles": [
    {
      "code": "knowledge_admin",
      "name": "Knowledge Admin",
      "permissions": [
        "app:knowledge:ask",
        "ai:knowledge:list",
        "ai:knowledge:create",
        "ai:knowledge:document:list",
        "ai:knowledge:document:create",
        "ai:knowledge:ask",
        "ai:chatFlow:list",
        "ai:chatFlow:create",
        "ai:chatFlow:message",
        "ai:eval:run",
        "ai:template:list"
      ]
    },
    {
      "code": "knowledge_user",
      "name": "Knowledge User",
      "permissions": [
        "app:knowledge:ask",
        "ai:knowledge:list",
        "ai:knowledge:ask",
        "ai:chatFlow:list",
        "ai:chatFlow:create",
        "ai:chatFlow:message"
      ]
    }
  ],
  "menus": [
    {
      "code": "knowledge.ask",
      "title": "Ask Knowledge",
      "path": "/knowledge",
      "permission": "app:knowledge:ask"
    },
    {
      "code": "knowledge.sources",
      "title": "Sources",
      "path": "/knowledge/sources",
      "permission": "ai:knowledge:list"
    }
  ],
  "prompts": [
    {
      "code": "kb_chat_answer",
      "name": "Cited Knowledge Answer",
      "content": "Answer with grounded citations. If the knowledge base does not contain the answer, say that the answer is not available in the configured sources."
    }
  ],
  "skills": [
    {
      "code": "cited_answer",
      "name": "Cited Answer",
      "description": "Builds grounded answers from retrieved chunks and citations."
    }
  ],
  "connectors": [
    {
      "code": "web.import",
      "name": "Web Import",
      "kind": "web",
      "authType": "none"
    }
  ],
  "plugins": [],
  "triggers": [],
  "evalSets": [
    {
      "code": "knowledge_base_regression",
      "name": "Knowledge Base Regression",
      "caseCount": 8,
      "metrics": ["citation_accuracy", "retrieval_recall"]
    }
  ],
  "deploymentChecklist": [
    "Create knowledge datasets and visibility policy",
    "Configure embedding and answer model routes",
    "Import source documents",
    "Run knowledge_base_regression eval set"
  ]
}
