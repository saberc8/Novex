{
  "code": "customer_service_agent",
  "name": "Customer Service Agent",
  "category": "agent",
  "description": "Customer-service agent template for grounded FAQ answers, tenant-scoped customer lookup, approval-gated ticket creation, and human handoff.",
  "frontendEntry": "apps/customer-service-agent",
  "frontendApp": "customer-service-agent",
  "frontendPages": [
    {
      "code": "console",
      "title": "Service Console",
      "path": "/customer-service",
      "navLabel": "Console",
      "permission": "ai:customer-service:agent:run"
    },
    {
      "code": "runs",
      "title": "Agent Runs",
      "path": "/customer-service/runs",
      "navLabel": "Runs",
      "permission": "ai:customer-service:agent:list"
    },
    {
      "code": "knowledge",
      "title": "Service Knowledge",
      "path": "/customer-service/knowledge",
      "navLabel": "Knowledge",
      "permission": "ai:customer-service:read"
    }
  ],
  "smokeScript": "templates/customer-service-agent/smoke.sh",
  "smokeChecks": [
    {
      "code": "customer_service_agent_api",
      "name": "Customer Service Agent API Smoke",
      "workdir": "backend",
      "command": "cargo test -p backend-rust customer_service_ --offline"
    },
    {
      "code": "customer_service_agent_frontend",
      "name": "Customer Service Agent Frontend Smoke",
      "workdir": "apps/customer-service-agent",
      "command": "pnpm test"
    }
  ],
  "sort": 5,
  "status": 1,
  "branding": {
    "brandName": "Novex Service",
    "logoText": "CS",
    "primaryColor": "#0f766e",
    "publicUrl": "https://service.example.com"
  },
  "roles": [
    {
      "code": "customer_service_operator",
      "name": "Customer Service Operator",
      "permissions": [
        "ai:customer-service:agent:run",
        "ai:customer-service:agent:list",
        "ai:customer-service:read",
        "ai:knowledge:list",
        "ai:knowledge:ask"
      ]
    },
    {
      "code": "customer_service_supervisor",
      "name": "Customer Service Supervisor",
      "permissions": [
        "ai:customer-service:agent:run",
        "ai:customer-service:agent:list",
        "ai:customer-service:read",
        "ai:customer-service:ticket",
        "ai:customer-service:handoff",
        "ai:agent:resume",
        "ai:trace:list",
        "ai:eval:list",
        "ai:eval:run",
        "ai:eval:report"
      ]
    }
  ],
  "menus": [
    {
      "code": "customer_service.console",
      "title": "Service Console",
      "path": "/customer-service",
      "permission": "ai:customer-service:agent:run"
    },
    {
      "code": "customer_service.runs",
      "title": "Agent Runs",
      "path": "/customer-service/runs",
      "permission": "ai:customer-service:agent:list"
    },
    {
      "code": "customer_service.knowledge",
      "title": "Service Knowledge",
      "path": "/customer-service/knowledge",
      "permission": "ai:customer-service:read"
    }
  ],
  "prompts": [
    {
      "code": "customer_service_agent_policy",
      "name": "Customer Service Agent Policy",
      "content": "Answer from cited FAQ or knowledge chunks, say insufficient evidence when citations are missing, lookup customer context only within tenant scope, and request approval before ticket or handoff actions."
    }
  ],
  "skills": [],
  "connectors": [],
  "plugins": [
    {
      "code": "builtin.agent-tools",
      "name": "Built-in Agent Tools",
      "runtime": "builtin_adapter"
    }
  ],
  "triggers": [],
  "evalSets": [
    {
      "code": "customer-service-agent-regression",
      "name": "Customer Service Agent Regression",
      "caseCount": 8,
      "metrics": ["grounded_resolution", "citation_correctness", "handoff_accuracy"]
    }
  ],
  "deploymentChecklist": [
    "Import customer-service FAQ and policy documents into a tenant knowledge dataset",
    "Review customer.lookup hidden field policy before enabling production traffic",
    "Keep ticket.create and handoff.request approval-gated",
    "Run customer-service-agent-regression before rollout"
  ]
}
