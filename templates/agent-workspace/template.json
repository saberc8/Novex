{
  "code": "agent_workspace",
  "name": "Agent Workspace",
  "category": "agent",
  "description": "Tool-using workspace template for task automation, approvals, trace inspection, and controlled external actions.",
  "frontendEntry": "apps/agent-workspace",
  "frontendApp": "agent-workspace",
  "frontendPages": [
    {
      "code": "workspace",
      "title": "Agent Workspace",
      "path": "/agent",
      "navLabel": "Workspace",
      "permission": "ai:agent:run"
    },
    {
      "code": "approvals",
      "title": "Approvals",
      "path": "/agent/approvals",
      "navLabel": "Approvals",
      "permission": "ai:agent:resume"
    },
    {
      "code": "traces",
      "title": "Traces",
      "path": "/agent/traces",
      "navLabel": "Traces",
      "permission": "ai:trace:list"
    }
  ],
  "smokeChecks": [
    {
      "code": "agent_runtime_api",
      "name": "Agent Runtime API Smoke",
      "workdir": "backend",
      "command": "cargo test -p backend-rust agent --offline"
    }
  ],
  "sort": 3,
  "status": 1,
  "branding": {
    "brandName": "Novex Agent",
    "logoText": "AG",
    "primaryColor": "#7c3aed",
    "publicUrl": "https://agent.example.com"
  },
  "roles": [
    {
      "code": "agent_operator",
      "name": "Agent Operator",
      "permissions": ["ai:agent:run", "ai:agent:resume", "ai:tool:dryRun", "ai:trace:list", "ai:template:list"]
    },
    {
      "code": "agent_approver",
      "name": "Agent Approver",
      "permissions": ["ai:agent:resume", "ai:tool:audit:list"]
    }
  ],
  "menus": [
    {
      "code": "agent.workspace",
      "title": "Agent Workspace",
      "path": "/agent",
      "permission": "ai:agent:run"
    },
    {
      "code": "agent.approvals",
      "title": "Approvals",
      "path": "/agent/approvals",
      "permission": "ai:agent:resume"
    },
    {
      "code": "agent.traces",
      "title": "Traces",
      "path": "/agent/traces",
      "permission": "ai:trace:list"
    }
  ],
  "prompts": [
    {
      "code": "agent_workspace_react",
      "name": "Agent ReAct Policy",
      "content": "Plan before acting, use approved tools only, stop when budget or approval policy requires it, and summarize every external action."
    }
  ],
  "skills": [
    {
      "code": "task_planning",
      "name": "Task Planning",
      "description": "Routes user tasks into a bounded ReAct run graph."
    }
  ],
  "connectors": [
    {
      "code": "github.repo",
      "name": "GitHub Repository",
      "kind": "github",
      "authType": "oauth"
    },
    {
      "code": "feishu.message",
      "name": "Feishu Message",
      "kind": "feishu",
      "authType": "token"
    }
  ],
  "plugins": [
    {
      "code": "builtin.agent-tools",
      "name": "Built-in Agent Tools",
      "runtime": "builtin_adapter"
    }
  ],
  "triggers": [
    {
      "code": "agent.webhook",
      "name": "Agent Webhook",
      "sourceType": "webhook",
      "target": "agent_run"
    }
  ],
  "evalSets": [
    {
      "code": "agent_workspace_regression",
      "name": "Agent Workspace Regression",
      "caseCount": 10,
      "metrics": ["intent_accuracy", "tool_accuracy"]
    }
  ],
  "deploymentChecklist": [
    "Bind connector credentials independently from identity login",
    "Review tool risk and approval policy",
    "Configure run graph budget defaults",
    "Run agent_workspace_regression eval set"
  ]
}
