AUTH_JWT_SECRET=local-compose-change-this-secret-32chars-min

# Optional image overrides. Defaults match infra/docker-compose.yml.
# Use these to reuse local images during low-resource or offline POC smoke runs.
POSTGRES_IMAGE=postgres:16-alpine
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.18
MINIO_IMAGE=minio/minio:RELEASE.2025-01-20T14-49-07Z
MILVUS_IMAGE=milvusdb/milvus:v2.5.4
RUST_IMAGE=rust:1.85-bookworm
NODE_IMAGE=node:24-bookworm-slim

# Optional host port overrides. Container ports stay fixed for service-to-service calls.
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
BACKEND_PORT=4398
ADMIN_PORT=4399
TRAINING_WEB_PORT=4401
CHAT_WEB_PORT=4402
AGENT_WORKSPACE_PORT=4403

# Optional external integration credentials for live POC smoke runs.
GITHUB_CONNECTOR_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
FEISHU_WEBHOOK_URL=
RIGHT_CODE_DRAW_BASE_URL=
RIGHT_CODE_DRAW_API_KEY=

# Milvus standalone defaults used by infra/docker-compose.yml.
MILVUS_TOKEN=root:Milvus
