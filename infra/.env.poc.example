AUTH_JWT_SECRET=local-compose-change-this-secret-32chars-min
AUTH_JWT_TTL_HOURS=24
HTTP_PORT=4398
DATABASE_MAX_CONNECTIONS=5
DB_AUTO_MIGRATE=true
RUST_LOG=backend_rust=debug,tower_http=info

# Optional image overrides. Defaults match infra/docker-compose.yml.
# Use these to reuse local images during low-resource or offline POC smoke runs.
POSTGRES_IMAGE=postgres:16-alpine
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.18
MINIO_IMAGE=minio/minio:RELEASE.2025-01-20T14-49-07Z
MILVUS_IMAGE=milvusdb/milvus:v2.5.4
RABBITMQ_IMAGE=rabbitmq:4.0-management-alpine
REDIS_IMAGE=redis:7-alpine
RUST_IMAGE=rust:1.85-bookworm
PYTHON_IMAGE=python:3.12-slim
NODE_IMAGE=node:24-bookworm-slim

# Optional host port overrides. Container ports stay fixed for service-to-service calls.
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
REDIS_PORT=6379
BACKEND_PORT=4398
ADMIN_PORT=4399
TRAINING_WEB_PORT=4401
CHAT_WEB_PORT=4402
AGENT_WORKSPACE_PORT=4403

# Parser queue and callback settings.
PARSER_CALLBACK_TOKEN=local-parser-callback-token-change-me
PARSER_CALLBACK_USER_ID=1
PARSER_WORKER_ID=parser-worker-1
PARSER_WORKER_MODE=type-routed
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Optional external integration credentials for live POC smoke runs.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
RERANKER_API_KEY=
RERANKER_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
RERANKER_MODEL=qwen3-rerank
MINERU_TOKEN=
MINERU_TIMEOUT_SECONDS=120
GITHUB_CONNECTOR_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
FEISHU_WEBHOOK_URL=
RIGHT_CODE_DRAW_BASE_URL=
RIGHT_CODE_DRAW_API_KEY=

# Milvus standalone defaults used by infra/docker-compose.yml.
MILVUS_TOKEN=root:Milvus
